#!/bin/sh
# Run C or C++ code automatically.
# Author: Michelle Chen  License: MIT

program=$0
VERSION=0.2.0
LICENSE_NAME=MIT

unsupported_file_extension=unknown
unsupported_file_type=empty

show_version() {
    printf '%s\n' "$VERSION"
}

show_license() {
    printf '%s\n' "$LICENSE_NAME"
}

help_info() {
    printf 'Usage: %s [run] source.c [source.cpp ...] [-- args...]\n' "$program"
    printf '       %s [command]\n' "$program"
    printf '       %s help [command]\n' "$program"
    printf '\n'
    printf 'Commands:\n'
    printf '\tversion\t\tShow version info and exit\n'
    printf '\tlicense\t\tShow license info and exit\n'
    printf '\thelp\t\tShow help info and exit\n'
    printf '\trun\t\tCompile and run an application (default)\n'
    printf '\n'
    printf 'Environment variables:\n'
    printf '\tOUT_FILE\tName of output file (copied to current directory if set)\n'
    printf '\tCC\t\tSet C compiler, default to gcc\n'
    printf '\tCXX\t\tSet C++ compiler, default to g++\n'
    printf '\tCFLAGS\t\tCustom include paths and compiler flags for C\n'
    printf '\tCXXFLAGS\tCustom include paths and compiler flags for C++\n'
    printf '\tCPPFLAGS\tCommon preprocessor flags\n'
    printf '\tLDFLAGS\t\tCustom library paths / linker flags\n'
    printf '\tLIBS\t\tCustom libraries\n'
    printf '\tLD_LIBRARY_PATH\tCustom runtime library search path\n'
}

help_version() {
    printf 'Usage: %s version\n' "$program"
    printf '\n'
    printf 'Show version info and exit\n'
}

help_license() {
    printf 'Usage: %s license\n' "$program"
    printf '\n'
    printf 'Show license info and exit\n'
}

help_help() {
    printf 'Usage: %s help [command]\n' "$program"
    printf '\n'
    printf 'Show help info for [command] and exit\n'
}

help_run() {
    printf 'Usage: %s [run] source.c [source.cpp ...] [-- args...]\n' "$program"
    printf '\n'
    printf 'Compile and run a C or C++ program\n'
}

check_ext() {
    ext=$1

    if [ -z "$ext" ]; then
        printf 'No valid extension\n' >&2
        exit 1
    fi

    case "$ext" in
        *.cpp) printf '.cpp\n' ;;
        *.cxx) printf '.cxx\n' ;;
        *.cc)  printf '.cc\n' ;;
        *.c)   printf '.c\n' ;;
        *)
            printf 'Unsupported file: %s\n' "$1" >&2
            printf '%s\n' "$unsupported_file_extension"
            ;;
    esac
}

check_file_type() {
    ext=$1

    if [ -z "$ext" ]; then
        printf 'No valid extension\n' >&2
        exit 1
    fi

    case "$ext" in
        .c)
            printf 'c\n'
            ;;
        .cpp|.cxx|.cc)
            printf 'c++\n'
            ;;
        *)
            printf 'Unknown file extension: %s\n' "$ext" >&2
            printf '%s\n' "$unsupported_file_type"
            ;;
    esac
}

cleanup() {
    if [ -n "${builddir-}" ] && [ -d "$builddir" ]; then
        rm -rf -- "$builddir"
    fi
}

make_builddir() {
    if command -v mktemp >/dev/null 2>&1; then
        mktemp -d "${TMPDIR:-/tmp}/crun.XXXXXX"
    else
        dir="${TMPDIR:-/tmp}/crun.$$"
        (umask 077 && mkdir "$dir") || return 1
        printf '%s\n' "$dir"
    fi
}

compile_source() {
    compiler=$1
    obj=$2
    src=$3
    flags=$4

    # shellcheck disable=SC2086
    "$compiler" -c -o "$obj" $CPPFLAGS $flags "$src"
}

cmd=$1

if [ "$cmd" = "version" ]; then
    show_version
    exit 0
fi

if [ "$cmd" = "license" ]; then
    show_license
    exit 0
fi

if [ "$cmd" = "help" ]; then
    subcmd=$2
    case "$subcmd" in
        version) help_version ;;
        license) help_license ;;
        help)    help_help ;;
        run)     help_run ;;
        "")      help_info ;;
        *)
            printf 'Unknown subcommand: %s\n' "$subcmd" >&2
            exit 1
            ;;
    esac
    exit 0
fi

if [ "$cmd" = "run" ]; then
    shift
fi

: "${CC:=gcc}"
: "${CXX:=g++}"
: "${CFLAGS:=}"
: "${CXXFLAGS:=}"
: "${CPPFLAGS:=}"
: "${LDFLAGS:=}"
: "${LIBS:=}"

if ! command -v "$CC" >/dev/null 2>&1; then
    printf 'Please install %s\n' "$CC" >&2
    exit 1
fi

if ! command -v "$CXX" >/dev/null 2>&1; then
    printf 'Please install %s\n' "$CXX" >&2
    exit 1
fi

builddir=$(make_builddir) || {
    printf 'Failed to create temporary build directory\n' >&2
    exit 1
}
trap 'cleanup' EXIT HUP INT TERM

dest=$builddir/out
if [ -n "${OUT_FILE-}" ]; then
    case "$OUT_FILE" in
        */*)
            printf 'OUT_FILE must be a file name, not a path: %s\n' "$OUT_FILE" >&2
            exit 1
            ;;
    esac
    final_out=$OUT_FILE
else
    final_out=
fi

is_cpp=0
src_count=0
obj_list=
had_error=0

while [ $# -gt 0 ]; do
    if [ "$1" = "--" ]; then
        shift
        break
    fi

    file=$1
    shift

    FILE_EXT=$(check_ext "$file")
    if [ "$FILE_EXT" = "$unsupported_file_extension" ]; then
        had_error=1
        continue
    fi

    FILE_TYPE=$(check_file_type "$FILE_EXT")
    src_count=$((src_count + 1))
    objname=$builddir/obj_$src_count.o

    if [ "$FILE_TYPE" = "c" ]; then
        if ! compile_source "$CC" "$objname" "$file" "$CFLAGS"; then
            had_error=1
        fi
    elif [ "$FILE_TYPE" = "c++" ]; then
        is_cpp=1
        if ! compile_source "$CXX" "$objname" "$file" "$CXXFLAGS"; then
            had_error=1
        fi
    else
        had_error=1
    fi

    obj_list="${obj_list}${obj_list:+ }$objname"
done

if [ "$src_count" -eq 0 ]; then
    printf 'No input source files\n' >&2
    help_run >&2
    exit 1
fi

if [ "$had_error" -ne 0 ]; then
    exit 1
fi

if [ "$is_cpp" -eq 1 ]; then
    link_driver=$CXX
else
    link_driver=$CC
fi

# shellcheck disable=SC2086
if ! "$link_driver" -o "$dest" $obj_list $LDFLAGS $LIBS; then
    exit 1
fi

if [ -n "$final_out" ]; then
    if [ -e "$final_out" ]; then
        printf 'File already exists: %s\n' "$final_out" >&2
        exit 1
    fi
    cp -- "$dest" "$final_out" || exit 1
fi

if ! env LD_LIBRARY_PATH="${LD_LIBRARY_PATH-}" "$dest" "$@"; then
    exit 1
fi

exit 0
